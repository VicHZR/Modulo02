meta {
  name: PATCH USER
  type: http
  seq: 2
}

patch {
  url: https://api.github.com/user
  body: json
  auth: inherit
}

body:json {
  {
    "bio": "Actualizado desde BRUNO"
  }
  
}

tests {
  test("Status code should be 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("Bio should be updated", function () {
      const body = res.getBody();
      expect(body.bio).to.equal("Actualizado desde BRUNO");
  });
  
}

settings {
  encodeUrl: true
}
